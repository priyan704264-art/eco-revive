# ── FRONTEND Environment Variables ──
# Copy this file to .env.local for local development
# On Railway: set these as environment variables in the frontend service

# URL of your deployed backend Railway service (no trailing slash)
# Example: https://eco-revive-backend.up.railway.app
VITE_BACKEND_URL=https://your-backend-service.up.railway.app

# Supabase credentials (get from https://supabase.com/dashboard → project settings → API)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Groq API key (get from https://console.groq.com)
VITE_GROQ_API_KEY=your_groq_api_key

# Razorpay public key (get from https://dashboard.razorpay.com → Settings → API Keys)
VITE_RAZORPAY_KEY_ID=rzp_test_your_key_id
